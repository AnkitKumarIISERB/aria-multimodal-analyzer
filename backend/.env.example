# ML Pipeline Configuration
USE_CELERY=false              # true in production
AUDIO_WEIGHT=0.7              # fusion weight for audio modality
FACE_WEIGHT=0.3               # fusion weight for face modality
FACE_CONFIDENCE_THRESHOLD=0.6 # below this, face data is discarded

# Hugging Face Model Configuration
HF_MODEL_ID=microsoft/wavlm-base
HF_CACHE_DIR=/app/model_cache

# Infrastructure Configuration
REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql://...
